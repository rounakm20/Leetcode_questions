class Solution {
    public boolean isPalindrome(String s) {

        String lower = s.toLowerCase();
        String result = lower.replaceAll("[^a-zA-Z0-9]", "");

        for(int i = 0 ; i < result.length(); i++){
            int j = result.length() - 1 - i;

            if(result.charAt(i) != result.charAt(j)){
                return false;
            }
        }

        return true;
    }
}
